# Reference only. Copy the package-level examples into each application.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
AUTH_MODE=mock
MOCK_AUTH_ENABLED=true
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

API_ENVIRONMENT=development
API_AUTH_MODE=mock
API_MOCK_AUTH_ENABLED=true
API_LOG_LEVEL=INFO
API_CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+asyncpg://revenueos:local-development-only@localhost:5432/revenueos
API_CLERK_JWKS_URL=
API_CLERK_ISSUER=
API_CLERK_AUDIENCE=
API_WORKER_POLL_INTERVAL_SECONDS=1
API_WORKER_LEASE_DURATION_SECONDS=60
API_WORKER_HEARTBEAT_INTERVAL_SECONDS=20
API_WORKER_BASE_RETRY_DELAY_SECONDS=5
API_WORKER_MAX_RETRY_DELAY_SECONDS=300
API_WORKER_DEFAULT_MAX_ATTEMPTS=3
AI_PROVIDER=mock
API_AI_PROVIDER_MODEL_IDENTIFIER=mock-infrastructure-v1
API_AI_PROVIDER_TIMEOUT_SECONDS=10
API_AI_PROMPT_KEY=infrastructure_test
API_AI_STRUCTURED_OUTPUT_MAX_ATTEMPTS=3

# Server-only placeholders. AI_PROVIDER=openai sends the selected meeting
# transcript to OpenAI. Keep the key out of frontend/NEXT_PUBLIC variables.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_OUTPUT_TOKENS=4096
